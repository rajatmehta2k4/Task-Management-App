# Copy this file to .env and fill in your real values
# Never commit your real .env file to GitHub!

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Service key (NOT anon key) - found in Supabase Settings > API > service_role

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Get these from Google Cloud Console > APIs > Credentials

# Gmail for sending emails
GMAIL_SENDER_EMAIL=youremail@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
# Gmail App Password: Google Account > Security > 2FA > App Passwords

# App settings
FLASK_SECRET_KEY=some-random-long-string-change-this
FRONTEND_URL=http://localhost:3000